# Google Calendar Integration
# -------------------------------------------------------
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select an existing one)
# 3. Enable the "Google Calendar API" in APIs & Services > Library
# 4. Go to APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Add your domain to "Authorized JavaScript origins":
#    - http://localhost:3000  (for local development)
#    - https://your-production-domain.com  (for production)
# 7. Copy the Client ID below

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Firebase (Requisitions tab)
# -------------------------------------------------------
# 1. Go to https://console.firebase.google.com/ and create a new project
#    (recommended name: onboarding-reviews or similar — separate from Review-Contest-Tracker)
# 2. Add a web app (Project Settings > General > Your apps > </> Add app)
# 3. Copy the config values into the variables below
# 4. In Firebase console > Build > Firestore Database > Create database (start in production mode)
# 5. Add a basic security rule allowing reads/writes from your domain
# 6. Add these same env vars in Vercel > Project > Settings > Environment Variables

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

